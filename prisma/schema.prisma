datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(cuid())
  address       String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  stories       Story[]
  
}

model Story {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  username    String
  platform    String
  story       String   @db.Text
  price       Float    @default(0.7)
  likes       Int      @default(0)
  shares      Int      @default(0)
  verified    Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
    
  @@index([userId])
  @@index([platform])
}

model Comment {
  id        String   @id @default(cuid())
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id])
  
  author    String
  address   String
  text      String   @db.Text
  
  createdAt DateTime @default(now())
  
  @@index([storyId])
}

model StoryValue {
  id        String   @id @default(cuid())
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id])
  
  from      String   // address
  amount    Float
  txHash    String?
  
  createdAt DateTime @default(now())
  
  @@index([storyId])
  @@index([from])
}

model SocialVerification {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  
  platform     String   // twitter, instagram, tiktok, etc
  platformId   String   // user ID di platform tersebut
  username     String
  verified     Boolean  @default(true)
  accessToken  String?  @db.Text
  refreshToken String?  @db.Text
  
  createdAt    DateTime @default(now())
  expiresAt    DateTime?
  
  @@unique([userId, platform])
  @@index([userId])
}

model PairedUsername {
  id            String   @id @default(cuid())
  username1     String
  username2     String
  pairedName    String   @unique
  creatorId     String
  
  currentPrice  Float    @default(0.7)
  totalVolume   Float    @default(0)
  
  createdAt     DateTime @default(now())
  
  trades        Trade[]
  
  @@index([creatorId])
}

model Trade {
  id              String   @id @default(cuid())
  pairedUsernameId String
  pairedUsername  PairedUsername @relation(fields: [pairedUsernameId], references: [id])
  
  from            String   // address
  to              String   // address
  price           Float
  txHash          String
  
  createdAt       DateTime @default(now())
  
  @@index([pairedUsernameId])
  @@index([from])
  @@index([to])
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  type      String   // withdraw, receive, value, trade
  amount    Float
  txHash    String?
  status    String   // pending, completed, failed
  
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([type])
}